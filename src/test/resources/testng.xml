<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  TestNG master suite file.

  How to run:
    All tests (default):       ./mvnw test
    Housing only:                ./mvnw test -Dgroups=housing
    Headless + staging env:    ./mvnw test -Dheadless=true

  Parallel execution:
    Set parallel="classes" and thread-count="2" to run each test
    class in its own thread (each class owns its own BrowserManager).
-->
<suite name="Playwright-Kotlin Automation Suite" verbose="1">

    <!-- ── Housing tests – fast feedback cycle ────────────────────────────── -->
    <test name="Housing Tests" groups="housing">
        <groups>
            <run>
                <include name="housing"/>
            </run>
        </groups>
        <classes>
            <class name="com.teckro.automation.tests.HousingTest"/>
        </classes>
    </test>

</suite>
