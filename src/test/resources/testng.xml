<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  TestNG master suite file.

  How to run:
    All tests (default):       ./mvnw test
    Smoke only:                ./mvnw test -Dgroups=smoke
    Different browser:         ./mvnw test -Dbrowser=firefox
    Headless + staging env:    ./mvnw test -Dheadless=true -Denv=staging

  Parallel execution:
    Set parallel="classes" and thread-count="2" to run each test
    class in its own thread (each class owns its own BrowserManager).
-->
<suite name="Playwright-Kotlin Automation Suite" verbose="1">

    <!-- ── Smoke tests – fast feedback cycle ────────────────────────────── -->
    <test name="Smoke Tests" groups="smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.teckro.automation.tests.LoginTest"/>
            <class name="com.teckro.automation.tests.DashboardTest"/>
        </classes>
    </test>

    <!-- ── Regression tests – full coverage ─────────────────────────────── -->
    <test name="Regression Tests" groups="regression">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.teckro.automation.tests.LoginTest"/>
            <class name="com.teckro.automation.tests.DashboardTest"/>
        </classes>
    </test>

</suite>
